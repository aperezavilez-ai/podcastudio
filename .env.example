# Copia este archivo a .env.local y pega tus claves reales.
# .env.local NO se sube a GitHub (está en .gitignore).

# Claude — solo servidor
ANTHROPIC_API_KEY=sk-ant-api03-...

# Resend — solo servidor
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=PodcastStudio <notificaciones@podcaststudio.mx>

# Stripe — solo servidor
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ANNUAL=price_...
SITE_URL=https://podcastudio-three.vercel.app
# Cuando podcaststudio.mx tenga DNS en Vercel, cambia a: https://podcaststudio.mx
VITE_SITE_URL=https://podcastudio-three.vercel.app

# Supabase — también en Vercel (redeploy tras cambiar)
VITE_SUPABASE_URL=https://fzoiuyyvzhgqcjceagkd.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mux — subida automática de grabaciones (VOD)
MUX_TOKEN_ID=...
MUX_TOKEN_SECRET=...
MUX_WEBHOOK_SECRET=...

# Restream — multistream en vivo (sin OBS)
RESTREAM_API_TOKEN=...

# Livepeer — WebRTC desde el navegador hacia Restream
LIVEPEER_API_KEY=...

# YouTube OAuth — publicar VOD tras procesar en Mux
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
